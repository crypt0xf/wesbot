# =============================================================================
# wesbot — .gitignore
# =============================================================================

# --- Secrets / local config ---
.env
.env.local
.env.*.local
cookies.txt

# --- Node / pnpm / TS ---
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo

# --- Turborepo ---
.turbo/

# --- Next.js ---
.next/
out/
next-env.d.ts

# --- Build output ---
dist/
build/
coverage/
playwright-report/
test-results/

# --- Prisma ---
prisma/migrations/dev.db*
**/*.db-journal

# --- Python (legacy) ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/

# --- Virtual environments ---
venv/
.venv/
env/

# --- Logs ---
*.log
logs/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editors ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.swp
*.swo
