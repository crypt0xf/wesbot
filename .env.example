# =============================================================================
# wesbot — Environment variables template
# Copy to .env (gitignored) and fill in values.
# =============================================================================

# --- Runtime ------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# --- Discord bot --------------------------------------------------------------
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_PUBLIC_KEY=
# Optional: guild ID to register slash commands instantly during development
DISCORD_DEV_GUILD_ID=

# --- Bot health probes --------------------------------------------------------
BOT_HEALTH_HOST=127.0.0.1
BOT_HEALTH_PORT=4100

# --- Dashboard (Next.js / Auth.js v5) -----------------------------------------
NEXTAUTH_URL=http://localhost:3000
# Shared secret for Auth.js JWTs — used by BOTH dashboard and API.
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Alias accepted by Auth.js v5 (you may use either name)
# NEXTAUTH_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- API (Fastify) ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=4000
# Generate with: openssl rand -base64 32
SESSION_SECRET=
# Must match AUTH_SECRET above so the API can verify dashboard JWTs
AUTH_SECRET=
# Comma-separated origins allowed to call the API
API_CORS_ORIGINS=http://localhost:3000

# --- Database (Postgres via Prisma) -------------------------------------------
DATABASE_URL=postgresql://wesbot:wesbot@localhost:5432/wesbot?schema=public

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Lavalink v4 (docker-compose service) -------------------------------------
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# --- Optional: Spotify (LavaSrc plugin will use these) ------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Optional: Apple Music (LavaSrc) ------------------------------------------
APPLE_MUSIC_TOKEN=

# --- Optional: Deezer (LavaSrc — no auth required for public tracks) ----------

# --- Optional: Lyrics ---------------------------------------------------------
# lrclib.net is used by default (no auth). Genius is the fallback.
GENIUS_ACCESS_TOKEN=

# --- Optional: Sentry ---------------------------------------------------------
SENTRY_DSN=
